{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      { "command": "python -u .\\hooks\\set-status.py busy" }
    ],
    "preToolUse": [
      { "command": "python -u .\\hooks\\set-status.py busy" }
    ],
    "subagentStart": [
      { "command": "python -u .\\hooks\\set-status.py busy" }
    ],
    "afterAgentThought": [
      { "command": "python -u .\\hooks\\set-status.py thinking" }
    ],
    "afterAgentResponse": [
      { "command": "python -u .\\hooks\\set-status.py success" }
    ],
    "postToolUseFailure": [
      { "command": "python -u .\\hooks\\set-status.py error" }
    ],
    "stop": [
      { "command": "python -u .\\hooks\\set-status.py success" }
    ],
    "sessionEnd": [
      { "command": "python -u .\\hooks\\set-status.py success" }
    ]
  }
}
